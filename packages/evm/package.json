{
  "name": "@ink-sdk/evm",
  "version": "0.1.1",
  "description": "EVM adapter for Ink cross-chain function execution.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
