{
  "name": "@ink-sdk/sdk",
  "version": "0.2.1",
  "description": "Core Ink programmable cross-chain function execution SDK.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@ink-sdk/evm": "0.2.1",
    "@ink-sdk/ika-connector": "0.2.1",
    "@ink-sdk/solana": "0.2.1",
    "@ink-sdk/sui": "0.2.1",
    "@ink-sdk/types": "0.2.1"
  }
}
