{
  "name": "ink-sdk-workspace",
  "version": "0.1.1",
  "private": true,
  "description": "Ink programmable cross-chain function execution SDK workspace.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/*",
    "typecheck": "tsc -b packages/* --pretty false",
    "test": "npm run build && node --test tests/*.test.mjs",
    "proof": "npm run proof:mock",
    "proof:mock": "npm run build && node examples/proof-execution.mjs",
    "proof:testnet": "npm run build && node examples/testnet-live-data.mjs",
    "proof:ika-sui": "node examples/ika-sui-cli-discovery.mjs",
    "proof:bnb-public": "node examples/bnb-public-function.mjs",
    "proof:ika-sign-bnb": "npm run build && node examples/ika-sign-bnb-transaction.mjs",
    "ika:refresh-presign": "node examples/refresh-ika-presign.mjs",
    "clean": "tsc -b packages/* --clean"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@ika.xyz/sdk": "^0.4.1",
    "@mysten/sui": "^2.18.0",
    "ethers": "^6.16.0"
  }
}
